digraph SundaiShip {
    graph [
        goal="Build a demoable Sundai MVP from the OpenSpec artifacts in $spec_dir/. \
Read changes/ for proposal, design, tasks, and capability specs. Also read spec/spec.md as the design-direction bridge when present. \
The app must include a real AI integration via OpenRouter (free model). \
All code goes in $app_dir/. After building, verify it runs and meets the design direction.",
        rankdir=LR,
        default_max_retry=2,
        retry_target="implement",
        fallback_retry_target="implement",
        model_stylesheet="
            *          { model: gpt-5.4;  }
            .cheap     { model: gpt-5.4;  }
        "
    ]

    exit [shape=Msquare, label="Exit"]

    start [shape=Mdiamond, label="Start"]

    // =========================================================================
    // Implement — write all the code
    // =========================================================================

    implement [
        shape=box,
        label="Implement",
        prompt="Read the project specification from OpenSpec artifacts:\n\
- $spec_dir/changes/*/proposal.md (what to build, success criteria, demo flow)\n\
- $spec_dir/changes/*/design.md (architecture, tech stack, key decisions, Design Direction)\n\
- $spec_dir/changes/*/tasks.md (dependency-ordered implementation steps)\n\
- All files in $spec_dir/changes/*/specs/ (detailed capability specs with acceptance criteria)\n\
- spec/spec.md when present (bridge summary + Design Direction details used by the Sundai pipeline)\n\n\
If $workflow_dir/verify_errors.log exists, read it FIRST and fix those errors.\n\n\
Build the full MVP inside $app_dir/:\n\
- All source code, configs, package files go in $app_dir/\n\
- Include a Dockerfile for Cloud Run deployment\n\
- AI must call OpenRouter via env vars OPENROUTER_BASE_URL, OPENROUTER_API_KEY, OPENROUTER_MODEL\n\
- Never hardcode secrets\n\
- Make the UI clean and demoable\n\
- Include a README with setup instructions\n\
- Follow the tasks.md dependency order when building\n\n\
IMPORTANT — Design Direction: Read spec/spec.md first when present, then use design.md/proposal.md to confirm decisions.\n\
Use the specified color palette, font pairing, and layout style throughout the UI.\n\
Do not use default framework colors or generic styling — the spec defines the visual target.\n\
If a reference design system is named (e.g., 'Linear-inspired', 'Stripe-inspired'),\n\
match that aesthetic in component styling, spacing, and color usage."
    ]

    // =========================================================================
    // Verify — install deps, lint, test, build
    // =========================================================================

    verify_deps [
        shape=parallelogram,
        label="Install Deps",
        max_retries=0,
        script="APP_DIR=$app_dir bash fabro/workflows/generic-build/scripts/install-deps.sh 2>&1"
    ]
    gate_deps [shape=diamond, label="Deps OK?"]

    verify_lint [
        shape=parallelogram,
        label="Lint",
        script="APP_DIR=$app_dir bash fabro/workflows/generic-build/scripts/lint.sh 2>&1"
    ]
    gate_lint [shape=diamond, label="Lint OK?"]

    fix_lints [
        label="Fix Lints",
        prompt="The lint check failed. Read the lint output from context and fix all issues in $app_dir/.",
        max_visits=3
    ]

    verify_build [
        shape=parallelogram,
        label="Build",
        goal_gate=true,
        script="APP_DIR=$app_dir bash fabro/workflows/generic-build/scripts/build.sh 2>&1"
    ]
    gate_build [shape=diamond, label="Build OK?"]

    // =========================================================================
    // Polish — design quality pass
    // =========================================================================

    polish [
        label="Polish",
        max_visits=2,
        prompt="@prompts/polish.md"
    ]

    design_check [
        shape=tab,
        label="Design Check",
        prompt="@prompts/design-check.md"
    ]
    gate_design [shape=diamond, label="Design OK?"]

    // =========================================================================
    // Edges
    // =========================================================================

    start -> implement

    implement -> verify_deps
    verify_deps -> gate_deps
    gate_deps -> verify_lint [condition="outcome=success"]
    gate_deps -> implement

    verify_lint -> gate_lint
    gate_lint -> verify_build [condition="outcome=success"]
    gate_lint -> fix_lints
    fix_lints -> verify_lint

    verify_build -> gate_build
    gate_build -> polish [condition="outcome=success"]
    gate_build -> implement

    // Polish -> Design Check -> Exit (only when design passes)
    polish -> design_check
    design_check -> gate_design
    gate_design -> exit [condition="context.design_ok=true"]
    gate_design -> polish
}
